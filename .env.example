# Copy to .env and fill in — never commit .env
# ==========================================================================

# Flask
FLASK_ENV=development                # development | production | testing
SECRET_KEY=generate-a-long-random-string
APP_BASE_URL=http://localhost:5000

# Database
# Local dev: leave empty to use SQLite (rentmate.db in project root)
# Production (cPanel MySQL): mysql+pymysql://user:pass@host/dbname
DATABASE_URL=

# Twilio — phone OTP verification
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=           # Verify API service SID (start with VA)

# OpenAI — AI preference interviewer
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Maps — address autocomplete + geocoding
GOOGLE_MAPS_API_KEY=

# Firebase — Firestore chat + Cloud Messaging
# Path to service-account JSON file (downloadable from Firebase console)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=
# Client-side Firebase config (exposed to browser — OK to be public)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_VAPID_KEY=

# Cloudinary — listing image hosting
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limit backend (leave empty for in-memory dev)
# REDIS_URL=redis://localhost:6379/0

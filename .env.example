# Copy to .env and edit for local dev
FLASK_ENV=dev
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///rentmate.db

# Leave unset for in-memory dev; set for multi-instance Socket.IO + rate limit
# REDIS_URL=redis://localhost:6379/0

# MailHog defaults for local dev — set real SMTP for production
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@rentmate.local

APP_BASE_URL=http://localhost:5000

# Required in non-debug mode; used for token signing + Flask session security.
SECRET_KEY=replace-with-long-random-string

# Frontend origin(s) allowed to call the API. Comma-separated. Use "*" only for throwaway dev.
ALLOWED_ORIGIN=http://localhost:5173

# Flask debug mode. Never enable in production.
FLASK_DEBUG=false
PORT=5000

# Database. Default is a local SQLite file next to app.py.
# DATABASE_URL=mysql+pymysql://user:pass@localhost/db_name

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20

# Auth / OTP
TOKEN_TTL_SECONDS=604800
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# Return the OTP in the /api/auth/login response for demo builds. Set false once SMS is wired up.
EXPOSE_OTP=true

# Chat limits
CHAT_MAX_CHARS=2000
CHAT_MIN_INTERVAL_SECONDS=2
CHAT_MAX_PER_HOUR=60

LOG_LEVEL=INFO

# Base URL of the RentMate backend. Only vars prefixed with VITE_ are exposed to client code.
VITE_API_BASE=http://localhost:5000

# Demo mode: when true, the frontend skips the backend entirely. Login accepts any phone with
# OTP "1234", chat is canned, swipe uses static cards. Use for static-hosted demos.
VITE_DEMO_MODE=true
